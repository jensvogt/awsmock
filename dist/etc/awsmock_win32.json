        "lifetime": 3600,
        "data-dir": "C:\\Program Files\\awsmock\\data\\lambda",
        "remove-period": 300,
        "counter-period": 300,
        "log-retention-period": 1,
        "private-port": 8080,
        "max-invocation-count": 3,
        "invocation-timeout": 5,
        "runtime": {
          "java11": "public.ecr.aws/lambda/java:11",
          "java17": "public.ecr.aws/lambda/java:17",
          "java21": "public.ecr.aws/lambda/java:21",
          "java25": "public.ecr.aws/lambda/java:25",
          "java26": "public.ecr.aws/lambda/java:26",
          "python3-9": "public.ecr.aws/lambda/python:3.9",
