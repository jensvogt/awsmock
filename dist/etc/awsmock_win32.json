{
  "awsmock": {
    "region": "eu-central-1",
    "user": "none",
    "access": {
      "key-id": "none",
      "account-id": "000000000000",
      "client-id": "00000000",
      "secret-access-key": "none"
    },
    "data-dir": "C:\\Program Files\\awsmock\\data",
    "temp-dir": "C:\\Program Files\\awsmock\\data\\tmp",
    "backup-dir": "C:\\Program Files\\awsmock\\data\\backup",
    "json": {
      "pretty": false
    },
    "aws": {
      "signature": {
        "verify": false
      }
    },
    "dockerized": false,
    "magic-file": "C:\\Program Files\\awsmock\\etc\\magic.mgc",
    "autoload": {
      "active": true,
      "file": "C:\\Program Files\\awsmock\\init\\01_init.json",
      "dir": "C:\\Program Files\\awsmock\\init"
    },
    "gateway": {
      "active": true,
      "http": {
        "host": "localhost",
        "address": "::",
        "port": 4566,
        "max-queue": 8,
        "max-thread": 64,
        "max-body": 536870912,
        "timeout": 900
      }
    },
    "modules": {
      "s3": {
        "active": true,
        "backup": {
          "active": true,
          "cron": "0 0 0 * * ?",
          "count": 5
        },
        "data-dir": "C:\\Program Files\\awsmock\\data\\s3",
        "counter-period": 60,
        "sync-period": 3600,
        "archive-timeout": 300
      },
      "sqs": {
        "active": true,
        "backup": {
          "active": true,
          "cron": "0 0 0 * * ?",
          "count": 5
        },
        "monitoring-period": 300,
        "reset-period": 30,
        "counter-period": 60,
        "receive-poll": 1000
      },
      "sns": {
        "active": true,
        "backup": {
          "active": true,
          "cron": "0 0 0 * * ?",
          "count": 5
        },
        "timeout": 14,
        "monitoring-period": 300,
        "delete-period": 300,
        "counter-period": 10
