<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*" Name="awsmock" Language="1033" Version="1.0.0" Manufacturer="MyCompany" UpgradeCode="PUT-A-GUID-HERE">
    <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine"/>

    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed."/>
    <MediaTemplate EmbedCab="yes"/>

    <Feature Id="ProductFeature" Title="Manager" Level="1">
      <ComponentGroupRef Id="ProductComponents"/>
    </Feature>
  </Product>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="awsmock"/>
      </Directory>
    </Directory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExecutable" Guid="7ad24e74-4e63-4003-8428-79872f46bcb3">
        <File Id="awsmockmgr.exe" Source="$(var.BuildDir)/awsmockmgr.exe" KeyPath="yes"/>
      </Component>
      <Component Id="AwsLocal" Guid="102a9b84-961f-46a4-a619-f314cf99e84b">
        <File Id="awslocal.exe" Source="$(var.BuildDir)/awslocal.exe" KeyPath="yes"/>
      </Component>
      <Component Id="AwsmockCtl" Guid="f3b4048d-6914-41bd-926a-0bf79643349a">
        <File Id="awsmockctl.exe" Source="$(var.BuildDir)/awsmockctl.exe" KeyPath="yes"/>
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>